Players.PlayerAdded:Connect(function(player)
	-- DataStoreмЧРмДЬ л°ЬлУЬ
	local data = loadPlayerData(player)

	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local wins = Instance.new("IntValue")
	wins.Name = "Wins"
	wins.Value = data.wins or 0
	wins.Parent = leaderstats

	local bestStreak = Instance.new("IntValue")
	bestStreak.Name = "BestStreak"
	bestStreak.Value = data.bestStreak or 0
	bestStreak.Parent = leaderstats

	local coins = Instance.new("IntValue")
	coins.Name = "Coins"
	coins.Value = data.coins or 0
	coins.Parent = leaderstats

	-- м†АмЮ•лРЬ мК§нВ® лН∞мЭінД∞ л≥µмЫР
	local owned = data.ownedSkins or { "кЄ∞л≥Є" }
	-- кЄ∞л≥Є мК§нВ®мЭі мЧЖмЬЉл©і мґФк∞А
	local hasDefault = false
	for _, s in ipairs(owned) do
		if s == "кЄ∞л≥Є" then hasDefault = true; break end
	end
	if not hasDefault then table.insert(owned, 1, "кЄ∞л≥Є") end

	playerSkins[player.UserId] = {
		owned = owned,
		active = data.activeSkin or "кЄ∞л≥Є",
	}

end)

-- нКЬнЖ†л¶ђмЦЉ мЭіл≤§нКЄ м≤Шл¶ђ (нБілЭЉмЭімЦЄнКЄ мЪФм≤≠/мЩДл£М)
rpsTutorial.OnServerEvent:Connect(function(player, data)
	if typeof(data) ~= "table" then return end

	if data.action == "check" then
		local cache = playerDataCache[player.UserId]
		local needTutorial = not (cache and cache.tutorialDone)
		rpsTutorial:FireClient(player, { needTutorial = needTutorial })

	elseif data.action == "done" then
		local cache = playerDataCache[player.UserId]
		if cache then
			cache.tutorialDone = true
		end
	end
end)

local function addCoins(player, amount)
	local ls = player:FindFirstChild("leaderstats")
	if ls and ls:FindFirstChild("Coins") then
		ls.Coins.Value += amount
	end
end

local function addWin(player)
	local ls = player:FindFirstChild("leaderstats")
	if not ls then return end
	if ls:FindFirstChild("Wins") then ls.Wins.Value += 1 end
end

local function updateBestStreak(player, currentStreak)
	local ls = player:FindFirstChild("leaderstats")
	if not ls then return end
	local best = ls:FindFirstChild("BestStreak")
	if best and currentStreak > best.Value then
		best.Value = currentStreak
	end
end

local function getActiveSkin(player)
	local data = playerSkins[player.UserId]
	local activeId = data and data.active or "кЄ∞л≥Є"
	for _, skin in ipairs(SKIN_DATA) do
		if skin.id == activeId then return skin end
	end
	return SKIN_DATA[1]
end

