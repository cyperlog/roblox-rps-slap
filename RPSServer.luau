	-- мЧђлЯђ л∞©нЦ•мЧРмДЬ лПЩмЛЬмЧР мЮђмГЭ (мЮЕм≤ік∞Р)
	for _, xDir in ipairs({-10, 10}) do
		playSound(sid, Vector3.new(xDir, 5, 0), 0.6, 0.8 + math.random() * 0.4)
	end
end

