local playerHistory = {} -- playerId вЖТ {choice, choice, ...}

local function getNPCChoice(npcName, playerId)
	local history = playerHistory[playerId] or {}

	if npcName == "нХЩмГЭ" then
		-- мЙђмЫА: мЩДм†Д лЮЬлН§
		return choicesList[math.random(1, 3)]

	elseif npcName == "к±ілЛђ" then
		-- к≥µк≤©м†Б: л∞ФмЬД 50%, к∞АмЬД 30%, л≥і 20%
		local r = math.random(100)
		if r <= 50 then return "л∞ФмЬД"
		elseif r <= 80 then return "к∞АмЬД"
		else return "л≥і" end

	elseif npcName == "нХ†мХДл≤ДмІА" then
		-- лКРкЄЛ: л≥і 50%, л∞ФмЬД 30%, к∞АмЬД 20%
		local r = math.random(100)
		if r <= 50 then return "л≥і"
		elseif r <= 80 then return "л∞ФмЬД"
		else return "к∞АмЬД" end

	elseif npcName == "л°ЬліЗ" then
		-- лґДмДЭнШХ: нФМл†ИмЭімЦік∞А к∞АмЮ• лІОмЭі лВЄ к±Є мєімЪінД∞ (40% нЩХл•†)
		if #history >= 3 then
			local counts = { ["к∞АмЬД"] = 0, ["л∞ФмЬД"] = 0, ["л≥і"] = 0 }
			for _, c in ipairs(history) do counts[c] = (counts[c] or 0) + 1 end
			local maxC, maxN = "к∞АмЬД", 0
			for c, n in pairs(counts) do
				if n > maxN then maxC, maxN = c, n end
			end
			if math.random(100) <= 40 then
				-- к∞АмЮ• лІОмЭі лВЄ к±Є мЭікЄ∞лКФ нМ®
				if maxC == "к∞АмЬД" then return "л∞ФмЬД"
				elseif maxC == "л∞ФмЬД" then return "л≥і"
				else return "к∞АмЬД" end
			end
		end
		return choicesList[math.random(1, 3)]

	elseif npcName == "лЛМмЮР" then
		-- мЦіл†§мЫА: мІБм†Д мД†нГЭмЭД мєімЪінД∞ (60% нЩХл•†)
		if #history >= 1 then
			local last = history[#history]
			if math.random(100) <= 60 then
				if last == "к∞АмЬД" then return "л∞ФмЬД"
				elseif last == "л∞ФмЬД" then return "л≥і"
				else return "к∞АмЬД" end
			end
		end
		return choicesList[math.random(1, 3)]

	elseif npcName == "кіСлМА" then
		-- мєімШ§мК§: лФ∞лЭЉнХШкЄ∞ 30%, мєімЪінД∞ 25%, лЮЬлН§ 45%
		if #history >= 1 then
			local last = history[#history]
			local r = math.random(100)
			if r <= 30 then
				return last -- лФ∞лЭЉнХШкЄ∞ (лєДкєА)
			elseif r <= 55 then
				if last == "к∞АмЬД" then return "л∞ФмЬД"
				elseif last == "л∞ФмЬД" then return "л≥і"
				else return "к∞АмЬД" end
			end
		end
		return choicesList[math.random(1, 3)]
	end

	return choicesList[math.random(1, 3)]
end

