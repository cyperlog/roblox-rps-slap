local playerDataStore = DataStoreService:GetDataStore("PlayerData_v1")

local DEFAULT_DATA = {
	coins = 0,
	wins = 0,
	bestStreak = 0,
	ownedSkins = { "кЄ∞л≥Є" },
	activeSkin = "кЄ∞л≥Є",
	tutorialDone = false,
}

local rpsTutorial = nil -- getOrCreate м†ХмЭШ нЫД міИкЄ∞нЩФлР®

local playerDataCache = {} -- userId вЖТ м†АмЮ•нХ† лН∞мЭінД∞

local function loadPlayerData(player)
	local key = "player_" .. player.UserId
	local success, data = pcall(function()
		return playerDataStore:GetAsync(key)
	end)

	if success and data then
		playerDataCache[player.UserId] = data
	else
		-- мЛ†кЈЬ нФМл†ИмЭімЦі лШРлКФ л°ЬлУЬ мЛ§нМ® вЖТ кЄ∞л≥Єк∞Т
		playerDataCache[player.UserId] = {
			coins = DEFAULT_DATA.coins,
			wins = DEFAULT_DATA.wins,
			bestStreak = DEFAULT_DATA.bestStreak,
			ownedSkins = { "кЄ∞л≥Є" },
			activeSkin = DEFAULT_DATA.activeSkin,
			tutorialDone = false,
		}
	end

	return playerDataCache[player.UserId]
end

local function savePlayerData(player)
	local data = playerDataCache[player.UserId]
	if not data then return end

	-- leaderstatsмЧРмДЬ мµЬмЛ† к∞Т лПЩкЄ∞нЩФ
	local ls = player:FindFirstChild("leaderstats")
	if ls then
		if ls:FindFirstChild("Coins") then data.coins = ls.Coins.Value end
		if ls:FindFirstChild("Wins") then data.wins = ls.Wins.Value end
		if ls:FindFirstChild("BestStreak") then data.bestStreak = ls.BestStreak.Value end
	end

	-- мК§нВ® лН∞мЭінД∞ лПЩкЄ∞нЩФ
	local skinData = playerSkins[player.UserId]
	if skinData then
		data.ownedSkins = skinData.owned
		data.activeSkin = skinData.active
	end

	local key = "player_" .. player.UserId
	local success, err = pcall(function()
		playerDataStore:SetAsync(key, data)
	end)

	if not success then
		warn("[RPS] лН∞мЭінД∞ м†АмЮ• мЛ§нМ® (" .. player.Name .. "): " .. tostring(err))
	end
end

